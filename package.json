{
  "name": "automate-mailing-counters",
  "version": "1.0.0",
  "description": "Automated SNMP printer counter reporting via email with CRON scheduling",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:run": "tsx src/index.ts --run-now",
    "once": "tsx src/index.ts --once",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:run": "node dist/index.js --run-now",
    "start:once": "node dist/index.js --once",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "net-snmp": "^3.26.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
