# ──────────────────────────────────────────────────────────────
# Automate Mailing Counters — Environment Configuration
# Copia este archivo como .env y llena los valores reales.
# NUNCA commitees el archivo .env con credenciales.
# ──────────────────────────────────────────────────────────────

# SNMP Configuration
SNMP_COMMUNITY=public

# SMTP Configuration (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password

# Mail Recipients (comma-separated para multiples destinatarios)
MAIL_FROM=your-email@example.com
MAIL_TO=recipient1@example.com,recipient2@example.com

# Error Notification Recipients — equipo de soporte (comma-separated, REQUERIDO)
ERROR_MAIL_TO=soporte1@example.com,soporte2@example.com

# ──────────────────────────────────────────────────────────────
# CRON Schedule
# ──────────────────────────────────────────────────────────────
# Formato: minuto hora dia-del-mes mes dia-de-la-semana
#
# Esta config ejecuta el reporte a las 8 AM en los dias 28-31 de cada mes.
# node-cron ignora automaticamente los dias que no existen en un mes:
#   - Enero (31 dias):   corre el 28, 29, 30 y 31
#   - Abril (30 dias):   corre el 28, 29 y 30 (ignora 31)
#   - Febrero (28 dias): corre solo el 28 (ignora 29, 30, 31)
#   - Febrero bisiesto:  corre el 28 y 29
#
# Con que el pipeline sea exitoso en UNO de esos dias, el reporte
# del mes queda cubierto. Los reintentos (MAX_RETRIES) cubren
# fallos transitorios dentro de cada ejecucion.
CRON_SCHEDULE=0 8 28-31 * *

# ──────────────────────────────────────────────────────────────
# Retry Configuration
# ──────────────────────────────────────────────────────────────
# Numero maximo de intentos si el pipeline falla (default: 3)
MAX_RETRIES=3

# Tiempo de espera entre reintentos, en segundos (default: 60)
RETRY_DELAY_SECONDS=60
